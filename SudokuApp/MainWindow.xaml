<Window x:Class="SudokuApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="数独解题程序"
        Height="760"
        Width="1100"
        MinHeight="700"
        MinWidth="980"
        WindowStartupLocation="CenterScreen"
        Background="#FFF7F5EF">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Vertical">
            <TextBlock Text="9x9 数独解题"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="#FF2A3B2E"/>
            <TextBlock Text="使用数字输入题目，结果展示前会进行数独规则验证。"
                       Margin="0,8,0,0"
                       Foreground="#FF4B5A50"
                       FontSize="14"/>
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,16,0,16"
                Padding="12"
            Background="#FFF2EEE3"
                CornerRadius="10">
            <WrapPanel VerticalAlignment="Center">
                <Button x:Name="SolveButton"
                        Content="求解"
                        Width="100"
                        Height="36"
                        Margin="0,0,10,0"
                        Click="SolveButton_Click"/>
                <Button x:Name="ClearButton"
                        Content="清空"
                        Width="100"
                        Height="36"
                        Click="ClearButton_Click"/>
            </WrapPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#FFFFFCF6"
                    CornerRadius="12"
                    Padding="16">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="题目输入"
                               FontWeight="SemiBold"
                               FontSize="16"
                               Margin="0,0,0,12"
                               Foreground="#FF263A33"/>
                    <UniformGrid x:Name="InputGrid" Rows="9" Columns="9"/>
                </DockPanel>
            </Border>

            <Border Grid.Column="2"
                    Background="#FFFFFCF6"
                    CornerRadius="12"
                    Padding="16">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="答案表格（9x9）"
                               FontWeight="SemiBold"
                               FontSize="16"
                               Margin="0,0,0,12"
                               Foreground="#FF263A33"/>
                    <UniformGrid x:Name="OutputGrid" Rows="9" Columns="9"/>
                </DockPanel>
            </Border>
        </Grid>

        <Border Grid.Row="3"
                Margin="0,16,0,0"
                Padding="12"
                CornerRadius="10"
                Background="#FFEBF4ED">
            <TextBlock x:Name="StatusText"
                       Text="就绪：请输入题目。"
                       Foreground="#FF1F4A31"
                       FontSize="14"/>
        </Border>
    </Grid>
</Window>
